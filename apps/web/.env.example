# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
CLERK_WEBHOOK_SECRET=whsec_...

# Neon (users/billing DB — separate from EidolonDB memory DB)
USERS_DATABASE_URL=postgresql://...

# Memory DB — accessed via EIDOLONDB_INTERNAL_URL (HTTP). Direct Postgres connection
# is only needed by apps/server. See apps/server/.env.example for MEMORIES_DATABASE_URL.

# Stripe setup:
# 1. Create products in Stripe Dashboard (test mode first)
# 2. Create a price for each: Developer ($19/mo recurring), Growth ($99/mo recurring)
# 3. Copy price IDs (price_xxx) into the env vars below
# 4. Add webhook endpoint: https://eidolondb.com/api/webhooks/stripe
#    Events: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_DEVELOPER_PRICE_ID=price_...
STRIPE_GROWTH_PRICE_ID=price_...

# Service key for server-side dashboard queries through the gateway
# Must match GATEWAY_SERVICE_KEY in apps/gateway
EIDOLONDB_SERVICE_KEY=eid_svc_e45661822ffa63ddae36383a905619f4f61b303a89597ffb

# Gateway public URL (used by dashboard server-side routes)
# Dev: set to http://localhost:3001 if running gateway locally, or https://api.eidolondb.com
EIDOLONDB_INTERNAL_URL=https://api.eidolondb.com
EIDOLONDB_ADMIN_TENANT=admin

# Resend (contact form + transactional email)
RESEND_API_KEY=re_...
