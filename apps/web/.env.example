# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
CLERK_WEBHOOK_SECRET=whsec_...

# Neon (users/billing DB — separate from EidolonDB memory DB)
USERS_DATABASE_URL=postgresql://...

# Memory DB — accessed via EIDOLONDB_INTERNAL_URL (HTTP). Direct Postgres connection
# is only needed by apps/server. See apps/server/.env.example for MEMORIES_DATABASE_URL.

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_DEVELOPER_PRICE_ID=price_...
STRIPE_GROWTH_PRICE_ID=price_...

# EidolonDB server URL — used by dashboard API routes (server-side only)
# Dev: http://localhost:3000
# Production: set to your Railway EidolonDB public URL (until private networking is configured)
EIDOLONDB_INTERNAL_URL=http://localhost:3000
EIDOLONDB_ADMIN_TENANT=admin
