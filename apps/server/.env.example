# EidolonDB Memory DB (PostgreSQL + pgvector)
# Local: postgresql://eidolon:eidolon@localhost:5492/eidolondb
# Production: set to your Railway/Neon connection string
MEMORIES_DATABASE_URL=postgresql://eidolon:eidolon@localhost:5492/eidolondb

# OpenAI (used for embeddings and LLM extraction)
OPENAI_API_KEY=sk-...

# Server config
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=development
