{
  "name": "@eidolondb/client",
  "version": "0.2.1",
  "description": "Official JavaScript/TypeScript client for EidolonDB",
  "repository": {
    "type": "git",
    "url": "https://github.com/millbj92/EidolonDB.git",
    "directory": "packages/sdk-js"
  },
  "homepage": "https://eidolondb.com/docs",
  "bugs": {
    "url": "https://github.com/millbj92/EidolonDB/issues"
  },
  "keywords": [
    "memory",
    "ai",
    "agents",
    "vector",
    "eidolondb"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config jest.config.js",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/jest": "^29.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.4.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  }
}
